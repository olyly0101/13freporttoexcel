<!doctype html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>13F 엑셀 정리기</title>
  <style>
    :root {
      --up: #e8f5e9;
      --down: #ffebee;
      --hold: #fffde7;
      --line: #222;
    }
    body {
      font-family: "Noto Sans KR", "Apple SD Gothic Neo", sans-serif;
      margin: 24px;
      color: #111;
    }
    .card {
      border: 1px solid #ddd;
      border-radius: 12px;
      padding: 16px;
      margin-bottom: 16px;
    }
    .row {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      align-items: center;
    }
    input[type="file"] {
      border: 1px solid #ccc;
      border-radius: 8px;
      padding: 8px;
    }
    button {
      border: 0;
      border-radius: 8px;
      background: #1b5e20;
      color: #fff;
      padding: 10px 14px;
      cursor: pointer;
      font-weight: 700;
    }
    button:disabled {
      background: #999;
      cursor: not-allowed;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px;
      table-layout: fixed;
    }
    th, td {
      border: 1px solid var(--line);
      padding: 6px;
      text-align: center;
      vertical-align: top;
      word-break: keep-all;
    }
    thead th {
      background: #f2f2f2;
      font-weight: 800;
    }
    .up { background: var(--up); }
    .down { background: var(--down); }
    .hold { background: var(--hold); }
    .sector-sep td { border-top: 3px solid #000; }
    .helper {
      font-size: 13px;
      color: #444;
      line-height: 1.45;
    }
  </style>
</head>
<body>
  <h1>13F 리포트 엑셀 정리기</h1>
  <div class="card">
    <div class="row">
      <input id="fileInput" type="file" accept=".xlsx,.xls,.csv" />
      <button id="downloadBtn" disabled>정리된 엑셀 다운로드</button>
    </div>
    <p class="helper">
      입력 파일에 다음 열이 있으면 자동 인식됩니다: <b>섹터, 티커, %변화, 비고, 구분(확대/축소/유지)</b>.<br/>
      영문 헤더(예: sector, ticker, change, note, action)도 인식합니다.
    </p>
  </div>

  <div class="card">
    <h2>미리보기</h2>
    <div style="overflow:auto; max-height: 70vh;">
      <table id="previewTable">
        <thead>
          <tr>
            <th style="width:90px;">섹터</th>
            <th class="up" style="width:120px;">지분 확대(티커)</th>
            <th class="up" style="width:90px;">% 변화</th>
            <th class="up" style="width:220px;">비고</th>
            <th class="down" style="width:120px;">지분 축소(티커)</th>
            <th class="down" style="width:90px;">% 변화</th>
            <th class="down" style="width:220px;">비고</th>
            <th class="hold" style="width:120px;">유지(티커)</th>
            <th class="hold" style="width:220px;">비고</th>
          </tr>
        </thead>
        <tbody></tbody>
      </table>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
  <script>
    const fileInput = document.getElementById('fileInput');
    const downloadBtn = document.getElementById('downloadBtn');
    const previewBody = document.querySelector('#previewTable tbody');

    let currentWorkbook = null;

    const alias = {
      sector: ['섹터', 'sector', '업종'],
      ticker: ['티커', 'ticker', 'symbol', '종목'],
      change: ['%변화', '변화', 'change', '% change', 'pct change'],
      note: ['비고', 'note', '회사 정보', 'company info', 'description'],
      action: ['구분', 'action', 'status', '변동유형', 'increase/decrease/hold']
    };

    function findHeader(row, candidates) {
      const normalized = row.map(v => String(v ?? '').trim().toLowerCase());
      for (const key of candidates) {
        const idx = normalized.indexOf(key.toLowerCase());
        if (idx >= 0) return idx;
      }
      return -1;
    }

    function normalizeAction(v) {
      const t = String(v ?? '').trim().toLowerCase();
      if (!t) return '';
      if (/(확대|증가|매수|신규|increase|add|buy|new)/.test(t)) return '확대';
      if (/(축소|감소|매도|청산|decrease|reduce|trim|sell|exit)/.test(t)) return '축소';
      if (/(유지|hold|same|keep)/.test(t)) return '유지';
      return '';
    }

    function inferActionByChange(changeValue) {
      const t = String(changeValue ?? '').trim();
      if (!t || /^new$/i.test(t)) return '확대';
      const num = Number(t.replace('%', '').replace('+', '').replace(/,/g, ''));
      if (Number.isFinite(num)) {
        if (num > 0) return '확대';
        if (num < 0) return '축소';
        return '유지';
      }
      return '유지';
    }

    function toRecords(aoa) {
      if (!aoa.length) return [];
      const header = aoa[0];
      const idxSector = findHeader(header, alias.sector);
      const idxTicker = findHeader(header, alias.ticker);
      const idxChange = findHeader(header, alias.change);
      const idxNote = findHeader(header, alias.note);
      const idxAction = findHeader(header, alias.action);

      if (idxSector < 0 || idxTicker < 0) {
        throw new Error('헤더를 찾을 수 없습니다. 최소한 "섹터"와 "티커" 열이 필요합니다.');
      }

      const out = [];
      for (let i = 1; i < aoa.length; i += 1) {
        const row = aoa[i] || [];
        const sector = String(row[idxSector] ?? '').trim();
        const ticker = String(row[idxTicker] ?? '').trim().toUpperCase();
        const change = idxChange >= 0 ? String(row[idxChange] ?? '').trim() : '';
        const note = idxNote >= 0 ? String(row[idxNote] ?? '').trim() : '';
        if (!sector || !ticker) continue;

        const actionRaw = idxAction >= 0 ? row[idxAction] : '';
        const action = normalizeAction(actionRaw) || inferActionByChange(change);
        out.push({ sector, ticker, change, note, action });
      }
      return out;
    }

    function groupBySector(records) {
      const order = ['확대', '축소', '유지'];
      const sectors = new Map();
      for (const r of records) {
        if (!sectors.has(r.sector)) {
          sectors.set(r.sector, { 확대: [], 축소: [], 유지: [] });
        }
        sectors.get(r.sector)[order.includes(r.action) ? r.action : '유지'].push(r);
      }
      return sectors;
    }

    function buildWideRows(sectorMap) {
      const rows = [];
      sectorMap.forEach((bucket, sector) => {
        const maxLen = Math.max(bucket.확대.length, bucket.축소.length, bucket.유지.length, 1);
        for (let i = 0; i < maxLen; i += 1) {
          const u = bucket.확대[i] || {};
          const d = bucket.축소[i] || {};
          const h = bucket.유지[i] || {};
          rows.push({
            섹터: i === 0 ? sector : '',
            지분확대티커: u.ticker || '',
            확대변화: u.change || '',
            확대비고: u.note || '',
            지분축소티커: d.ticker || '',
            축소변화: d.change || '',
            축소비고: d.note || '',
            유지티커: h.ticker || '',
            유지비고: h.note || '',
            _sectorStart: i === 0
          });
        }
      });
      return rows;
    }

    function renderPreview(rows) {
      previewBody.innerHTML = '';
      rows.forEach((r, idx) => {
        const tr = document.createElement('tr');
        if (r._sectorStart && idx !== 0) tr.className = 'sector-sep';
        tr.innerHTML = `
          <td>${r.섹터}</td>
          <td class="up"><b>${r.지분확대티커}</b></td>
          <td class="up">${r.확대변화}</td>
          <td class="up">${r.확대비고}</td>
          <td class="down"><b>${r.지분축소티커}</b></td>
          <td class="down">${r.축소변화}</td>
          <td class="down">${r.축소비고}</td>
          <td class="hold"><b>${r.유지티커}</b></td>
          <td class="hold">${r.유지비고}</td>
        `;
        previewBody.appendChild(tr);
      });
    }

    function buildWorkbook(records, wideRows) {
      const wb = XLSX.utils.book_new();

      const summary = records.map(r => ({
        섹터: r.sector,
        구분: r.action,
        티커: r.ticker,
        '%변화': r.change,
        비고: r.note
      }));

      const wsSummary = XLSX.utils.json_to_sheet(summary);
      XLSX.utils.book_append_sheet(wb, wsSummary, '정리결과');

      const wide = wideRows.map(r => ({
        섹터: r.섹터,
        '지분 확대(티커)': r.지분확대티커,
        '%변화(확대)': r.확대변화,
        '비고(확대)': r.확대비고,
        '지분 축소(티커)': r.지분축소티커,
        '%변화(축소)': r.축소변화,
        '비고(축소)': r.축소비고,
        '유지(티커)': r.유지티커,
        '비고(유지)': r.유지비고
      }));
      const wsWide = XLSX.utils.json_to_sheet(wide);
      XLSX.utils.book_append_sheet(wb, wsWide, '보기좋게');

      return wb;
    }

    fileInput.addEventListener('change', async (e) => {
      const f = e.target.files?.[0];
      if (!f) return;
      try {
        const data = await f.arrayBuffer();
        const wb = XLSX.read(data, { type: 'array' });
        const first = wb.SheetNames[0];
        const aoa = XLSX.utils.sheet_to_json(wb.Sheets[first], { header: 1, defval: '' });

        const records = toRecords(aoa);
        const grouped = groupBySector(records);
        const wideRows = buildWideRows(grouped);

        renderPreview(wideRows);
        currentWorkbook = buildWorkbook(records, wideRows);
        downloadBtn.disabled = false;
      } catch (err) {
        alert(`파일 처리 중 오류가 발생했습니다: ${err.message}`);
        downloadBtn.disabled = true;
        currentWorkbook = null;
      }
    });

    downloadBtn.addEventListener('click', () => {
      if (!currentWorkbook) return;
      const stamp = new Date().toISOString().slice(0, 10);
      XLSX.writeFile(currentWorkbook, `13f_정리_${stamp}.xlsx`);
    });
  </script>
</body>
</html>
